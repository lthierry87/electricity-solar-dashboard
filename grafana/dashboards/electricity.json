      "datasource": { "type": "influxdb", "uid": "electricity_influx" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#C0392B", "value": null },
              { "color": "#F5A623", "value": 40 },
              { "color": "#16A085", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "electricity_influx" },
