        "groupWidth": 0.7,
        "stacking": "none",
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" },
        "xTickLabelRotation": -30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "kwatth",
          "decimals": 2,
          "custom": { "fillOpacity": 80 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "consumption_wh" },
            "properties": [
              { "id": "displayName", "value": "Consumption" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#E05252" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "production_wh" },
            "properties": [
              { "id": "displayName", "value": "Production" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "grid_import_wh" },
            "properties": [
              { "id": "displayName", "value": "Grid Import" },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#C0392B" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "electricity_influx" },
          "refId": "A",
          "query": "from(bucket: \"electricity\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"electricity\")\n  |> filter(fn: (r) => r._field == \"consumption_wh\" or r._field == \"production_wh\" or r._field == \"grid_import_wh\")\n  |> aggregateWindow(every: 1d, fn: sum, createEmpty: false)\n  |> map(fn: (r) => ({r with _value: r._value / 1000.0}))"
        }
      ]
    },

    {
      "id": 7,
