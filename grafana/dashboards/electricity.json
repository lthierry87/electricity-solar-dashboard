          "query": "from(bucket: \"electricity\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"electricity\")\n  |> filter(fn: (r) => r._field == \"consumption_wh\" or r._field == \"grid_import_wh\")\n  |> sum()\n  |> pivot(rowKey: [\"_start\", \"_stop\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> map(fn: (r) => ({\n    _time: r._start,\n    _field: \"self_sufficiency\",\n    _measurement: \"electricity\",\n    _value: if r.consumption_wh > 0.0 then (1.0 - r.grid_import_wh / r.consumption_wh) * 100.0 else 0.0\n  }))"
        }
