    {
      "id": 9,
      "type": "gauge",
      "title": "Self-Consumption (period)",
      "description": "**Self-Consumption** answers: *how much of what I produced did I actually use myself?*\n\nFormula: `self_consumed / production × 100`\n\nA high value means little solar energy was wasted or exported — you used most of what your panels generated.",
      "gridPos": { "x": 19, "y": 22, "w": 5, "h": 9 },
      "datasource": { "type": "influxdb", "uid": "electricity_influx" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
